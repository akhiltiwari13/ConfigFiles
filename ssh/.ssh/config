Host quompt quomptblr
    HostName dev.passonwords.com
    User atiwari
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    ForwardAgent yes
    ServerAliveInterval 30
    ServerAliveCountMax 3
    TCPKeepAlive yes
    ControlMaster auto
    ControlPath ~/.ssh/agent/%r@%h:%p
    ControlPersist 10m
    # enabling display server forwarding.
    ForwardX11 yes
    ForwardX11Trusted no
    ForwardX11Timeout 596h
    Compression yes



