#vim/neovim related files.
*.swp
*.swo


node_modules
package-lock.json
package.json
lazy-lock.json

# don't search in the tag file generated by vim
*tags
Session.vim

# don't commit tmux plugins (cloned by TPM into stowed dirs at runtime)
tmux/.config/tmux/plugins/
omtmux/.config/tmux/plugins/
/lazyvim/nvim/.config/nvim/spell/en.utf-8.add.spl
/.sisyphus/plans

# OpenCode secrets and runtime
opencode/.config/opencode/antigravity-accounts.json
opencode/.config/opencode/antigravity-signature-cache.json
opencode/.config/opencode/antigravity-logs/
opencode/.config/opencode/node_modules/
opencode/.config/opencode/package.json
opencode/.config/opencode/bun.lock

# Claude Code runtime (not config)
claudecode/.claude/.credentials.json
claudecode/.claude/history.jsonl
claudecode/.claude/sessions/
claudecode/.claude/projects/
claudecode/.claude/cache/
claudecode/.claude/telemetry/
claudecode/.claude/backups/
claudecode/.claude/transcripts/
claudecode/.claude/session-env/
claudecode/.claude/file-history/
claudecode/.claude/paste-cache/
claudecode/.claude/debug/
claudecode/.claude/downloads/
claudecode/.claude/ide/
claudecode/.claude/tasks/
claudecode/.claude/shell-snapshots/
claudecode/.claude/.last-cleanup
claudecode/.claude/plans/
/.sisyphus

# Tmux server/client log files (e.g. when tmux runs from inside the configfiles dir)
tmux-server-*.log
tmux-client-*.log

# btop themes (auto-generated/runtime)
btop/.config/btop/themes/
/opencode/.config/opencode/opencode-notifier-state.json

# SSH: never commit private keys, known_hosts, or agent sockets even if package layout grows
ssh/.ssh/id_*
!ssh/.ssh/id_*.pub
ssh/.ssh/keys/
ssh/.ssh/known_hosts*
ssh/.ssh/agent/
/claudecode/.claude/policy-limits.json
/claudecode/.claude/plugins
