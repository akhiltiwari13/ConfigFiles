# Dayfox - light theme for btop
# Based on nightfox.nvim dayfox palette
# Upstream: https://github.com/EdenEast/nightfox.nvim/raw/main/extra/dayfox/alacritty.toml

# Main background, empty for terminal default
theme[main_bg]="#f6f2ee"

# Main text color
theme[main_fg]="#3d2b5a"

# Title color for boxes
theme[title]="#3d2b5a"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#2848a9"

# Background color of selected item in processes box
theme[selected_bg]="#e7d2be"

# Foreground color of selected item in processes box
theme[selected_fg]="#2848a9"

# Color of inactive/disabled text
theme[inactive_fg]="#9c8c80"

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="#643f61"

# Background color of the percentage meters
theme[meter_bg]="#d3c7bb"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#643f61"

# CPU, Memory, Network, Proc box outline colors
theme[cpu_box]="#287980"   # Cyan
theme[mem_box]="#396847"   # Green
theme[net_box]="#ac5402"   # Yellow/Orange
theme[proc_box]="#2848a9"  # Blue

# Box divider line and small boxes line color
theme[div_line]="#c8bdb2"

# Temperature graph color (Green -> Yellow -> Red)
theme[temp_start]="#396847"
theme[temp_mid]="#ac5402"
theme[temp_end]="#a5222f"

# CPU graph colors (Cyan -> Blue -> Magenta)
theme[cpu_start]="#287980"
theme[cpu_mid]="#2848a9"
theme[cpu_end]="#6e33ce"

# Mem/Disk free meter (Magenta -> Blue -> Cyan)
theme[free_start]="#6e33ce"
theme[free_mid]="#4863b6"
theme[free_end]="#287980"

# Mem/Disk cached meter (Blue -> Cyan -> Magenta)
theme[cached_start]="#4863b6"
theme[cached_mid]="#287980"
theme[cached_end]="#8452d5"

# Mem/Disk available meter (Yellow -> Orange -> Red)
theme[available_start]="#ac5402"
theme[available_mid]="#b86e28"
theme[available_end]="#a5222f"

# Mem/Disk used meter (Green -> Cyan -> Blue)
theme[used_start]="#396847"
theme[used_mid]="#287980"
theme[used_end]="#2848a9"

# Download graph colors (Yellow -> Orange -> Red)
theme[download_start]="#ac5402"
theme[download_mid]="#b86e28"
theme[download_end]="#a5222f"

# Upload graph colors (Green -> Cyan -> Blue)
theme[upload_start]="#396847"
theme[upload_mid]="#287980"
theme[upload_end]="#2848a9"

# Process box color gradient for threads, mem and cpu usage (Cyan -> Blue -> Magenta)
theme[process_start]="#287980"
theme[process_mid]="#4863b6"
theme[process_end]="#6e33ce"
