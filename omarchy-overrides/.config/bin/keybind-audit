#!/usr/bin/env bash
# keybind-audit — inventory keybindings across the dev stack and flag overlaps.
#
# Aggregates dumps from Hyprland, Ghostty, tmux, and Neovim into a single
# markdown report on stdout. No off-the-shelf AUR/pacman tool does this for the
# Omarchy + Hyprland + Ghostty + tmux + LazyVim stack, so this is a pragmatic
# v1: full inventory + a small flagged-chord checker for the high-risk overlap
# zones (C-Space, M-1..M-9, M-Left/Right/Up/Down, C-M-arrows). Visual scan
# beats false-positive automation for modal/scope-sensitive bindings.
#
# Usage: keybind-audit [--no-nvim]
#   --no-nvim   skip Neovim dump (faster; useful when nvim isn't on PATH)
#
# Exits 0 even when overlaps exist — this is a reporter, not a gate.

set -euo pipefail

WANT_NVIM=1
for arg in "$@"; do
  case "$arg" in
    --no-nvim) WANT_NVIM=0 ;;
    -h|--help) sed -n '2,/^$/p' "$0" | sed 's/^# //;s/^#//'; exit 0 ;;
    *) printf 'unknown arg: %s\n' "$arg" >&2; exit 2 ;;
  esac
done

have() { command -v "$1" >/dev/null 2>&1; }

section() { printf '\n## %s\n\n' "$1"; }
note()    { printf '> _%s_\n\n' "$1"; }

printf '# Keybind audit — %s\n' "$(date -Iseconds)"
note "Generated by bin/keybind-audit. See KEYBINDINGS.md for the leader hierarchy and rules."

# ── Hyprland ──────────────────────────────────────────────────────────────
section "Hyprland (hyprctl binds)"
if have hyprctl; then
  printf '```\n'
  hyprctl binds 2>/dev/null \
    | awk '/^bind/ { ev=$0 } /modmask:/ { mod=$2 } /key:/ { key=$2 } /dispatcher:/ { disp=$2 } /arg:/ { arg=substr($0,index($0,$2)); printf "%-22s mod=%s key=%s\n", disp" "arg, mod, key }' \
    | sort -u
  printf '```\n'
else
  note "hyprctl not on PATH — skipped."
fi

# ── Ghostty ───────────────────────────────────────────────────────────────
section "Ghostty (config keybind lines)"
GHOSTTY_CFG="$HOME/.config/ghostty/config"
if [[ -r "$GHOSTTY_CFG" ]]; then
  printf '```\n'
  grep -E '^[[:space:]]*keybind[[:space:]]*=' "$GHOSTTY_CFG" | sed 's/^[[:space:]]*//'
  printf '```\n'
elif have ghostty; then
  printf '```\n'
  ghostty +list-keybinds 2>/dev/null | head -80
  printf '```\n'
else
  note "Ghostty config not readable and ghostty CLI not on PATH — skipped."
fi

# ── tmux ──────────────────────────────────────────────────────────────────
section "tmux (live server: list-keys; otherwise: parse conf)"
if have tmux && tmux info >/dev/null 2>&1; then
  printf '_Live tmux server detected._\n\n'
  printf '```\n'
  tmux list-keys -aN 2>/dev/null | sort -u
  printf '```\n'
else
  printf '_No live tmux server. Showing static binds from conf files._\n\n'
  printf '```\n'
  for f in "$HOME/.config/tmux/tmux.conf" "$HOME/.config/tmux/tmux.user.conf"; do
    [[ -r "$f" ]] || continue
    printf '# %s\n' "$f"
    grep -E '^[[:space:]]*(bind|set -g @plugin|set -g @continuum)' "$f" || true
    printf '\n'
  done
  printf '```\n'
fi

# ── Neovim (LazyVim) ──────────────────────────────────────────────────────
section "Neovim / LazyVim (headless map dump)"
if [[ "$WANT_NVIM" -eq 1 ]] && have nvim; then
  TMP_NVIM_OUT="$(mktemp)"
  trap 'rm -f "$TMP_NVIM_OUT"' EXIT
  if nvim --headless -c 'silent! redir > '"$TMP_NVIM_OUT"'' -c 'silent! map' -c 'silent! redir END' -c 'qa!' >/dev/null 2>&1; then
    printf '```\n'
    sed -n '1,200p' "$TMP_NVIM_OUT"
    printf '```\n'
    if [[ "$(wc -l < "$TMP_NVIM_OUT")" -gt 200 ]]; then
      note "Truncated to first 200 lines. Run \`nvim -c ':map' -c ':only'\` for the full list."
    fi
  else
    note "nvim --headless map dump failed — skipped."
  fi
else
  note "Neovim dump skipped (--no-nvim or nvim not on PATH)."
fi

# ── Flagged chords ────────────────────────────────────────────────────────
section "High-risk chords (manual review)"
cat <<'EOF'
The cross-program audit pays special attention to these chord families,
which historically cause confusion when adopted by multiple layers:

| Chord family | Owned by (intended) | Notes |
|---|---|---|
| `C-Space` (prefix) | tmux | Owned cleanly. Hyprland uses `SUPER+SPACE` for walker; not a conflict. |
| `M-1`..`M-9` | tmux (window select, unprefixed) | Hyprland uses `SUPER+code:10..18`, not `M-`. Safe. |
| `M-Left/Right` | tmux (window prev/next) | Hyprland does not bind `M-arrows`. Safe. |
| `M-Up/Down` | tmux (session prev/next) | Same — Hyprland clear. |
| `C-M-arrows` | tmux (pane select) | Deep chord; nothing else binds it. Safe. |
| `<Space>` | LazyVim leader | tmux prefix is `C-Space`, not `Space`. Safe. |
| `prefix + Ctrl-s/r` | tmux-resurrect | No native tmux or Omarchy binding here. Safe. |
| `prefix + O` | tmux-sessionx | Capital O; lowercase `o` is unbound. Safe. |
| `prefix + Shift-P` etc. | tmux-logging | All `*-P` variants free in Omarchy base. Safe. |

If `keybind-audit` output above shows any of these chords being claimed by a
program OTHER than the intended owner, escalate to a remap. Update
KEYBINDINGS.md when the matrix changes.
EOF

section "End"
printf 'Generated %s on %s\n' "$(date -Iseconds)" "$(hostname)"
